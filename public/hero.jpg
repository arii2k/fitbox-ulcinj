Radinovi\u0107 zahvalnicu za postignute rezultate u istoj godini.\nSve pohvale za organizaciju, \u010destitke na\u0161im \u010dlanovima na novim priznanjima i \u017eelimo im da u narednoj godini posti\u017eu jo\u0161 bolje rezultate, kako oni, tako i ostali \u010dlanovi FIT BOX kluba."},"audience":null,"carousel_media_count":7,"display_uri":null,"media_type":8,"carousel_media":[{"image_versions2":{"candidates":[{"height":1536,"url":"https:\/\/instagram.ftgd2-1.fna.fbcdn.net\/v\/t51.82787-15\/619262946_18418533025188966_120910576603499905_n.jpg?stp=dst-jpg_e35_tt6&_nc_cat=108&ig_cache_key=MzgxNTg1OTQ0MDE0MjgxMTM4NQ\u00253D\u00253D.3-ccb7-5&ccb=7-5&_nc_sid=58cdad&efg=eyJ2ZW5jb2RlX3RhZyI6InhwaWRzLjExNTJ4MTUzNi5zZHIuQzMifQ\u00253D\u00253D&_nc_ohc=GP4EztoCzW0Q7kNvwHENYuh&_nc_oc=AdmTOtaGXdOkrWHuscxMJ7aV41U5cm77H-6Ff01cbibYUL-08R38mBxmTMXsuougq3g&_nc_ad=z-m&_nc_cid=0&_nc_zt=23&_nc_ht=instagram.ftgd2-1.fna&_nc_gid=tVnYUWbwH-DBK1rbBmxbVg&oh=00_AfuoQxbhhk9iPx9ZvVmG38c88qAu2MmXFf4ZUGK34in70Q&oe=69971562","width":1152},{"height":960,"url":"https:\/\/instagram.ftgd2-1.fna.fbcdn.net\/v\/t51.82787-15\/619262946_18418533025188966_120910576603499905_n.jpg?stp=dst-jpg_e35_p720x720_tt6&_nc_cat=108&ig_cache_key=MzgxNTg1OTQ0MDE0MjgxMTM4NQ\u00253D\u00253D.3-ccb7-5&ccb=7-5&_nc_sid=58cdad&efg=eyJ2ZW5jb2RlX3RhZyI6InhwaWRzLjExNTJ4MTUzNi5zZHIuQzMifQ\u00253D\u00253D&_nc_ohc=GP4EztoCzW0Q7kNvwHENYuh&_nc_oc=AdmTOtaGXdOkrWHuscxMJ7aV41U5cm77H-6Ff01cbibYUL-08R38mBxmTMXsuougq3g&_nc_ad=z-m&_nc_cid=0&_nc_zt=23&_nc_ht=instagram.ftgd2-1.fna&_nc_gid=tVnYUWbwH-DBK1rbBmxbVg&oh=00_Afv3vtdYdmZ1OQAu6G6BMIZzdbdRnZ89pxJr9YfcTbTyfA&oe=69971562","width":720},{"height":853,"url":"https:\/\/instagram.ftgd2-1.fna.fbcdn.net\/v\/t51.82787-15\/619262946_18418533025188966_120910576603499905_n.jpg?stp=dst-jpg_e35_p640x640_sh0.08_tt6&_nc_cat=108&ig_cache_key=MzgxNTg1OTQ0MDE0MjgxMTM4NQ\u00253D\u00253D.3-ccb7-5&ccb=7-5&_nc_sid=58cdad&efg=eyJ2ZW5jb2RlX3RhZyI6InhwaWRzLjExNTJ4MTUzNi5zZHIuQzMifQ\u00253D\u00253D&_nc_ohc=GP4EztoCz