":480},{"height":320,"url":"https:\/\/instagram.ftgd2-1.fna.fbcdn.net\/v\/t51.82787-15\/619262946_18418533025188966_120910576603499905_n.jpg?stp=c0.192.1152.1152a_dst-jpg_e35_s320x320_tt6&_nc_cat=108&ig_cache_key=MzgxNTg1OTQ0MDE0MjgxMTM4NQ\u00253D\u00253D.3-ccb7-5&ccb=7-5&_nc_sid=58cdad&efg=eyJ2ZW5jb2RlX3RhZyI6InhwaWRzLjExNTJ4MTUzNi5zZHIuQzMifQ\u00253D\u00253D&_nc_ohc=GP4EztoCzW0Q7kNvwHENYuh&_nc_oc=AdmTOtaGXdOkrWHuscxMJ7aV41U5cm77H-6Ff01cbibYUL-08R38mBxmTMXsuougq3g&_nc_ad=z-m&_nc_cid=0&_nc_zt=23&_nc_ht=instagram.ftgd2-1.fna&_nc_gid=tVnYUWbwH-DBK1rbBmxbVg&oh=00_AftJwQ-CrX8R7ZVZPs00s7Tu3q2OYWaFRz9vf0Qj5wgFvg&oe=69971562","width":320},{"height":240,"url":"https:\/\/instagram.ftgd2-1.fna.fbcdn.net\/v\/t51.82787-15\/619262946_18418533025188966_120910576603499905_n.jpg?stp=c0.192.1152.1152a_dst-jpg_e35_s240x240_tt6&_nc_cat=108&ig_cache_key=MzgxNTg1OTQ0MDE0MjgxMTM4NQ\u00253D\u00253D.3-ccb7-5&ccb=7-5&_nc_sid=58cdad&efg=eyJ2ZW5jb2RlX3RhZyI6InhwaWRzLjExNTJ4MTUzNi5zZHIuQzMifQ\u00253D\u00253D&_nc_ohc=GP4EztoCzW0Q7kNvwHENYuh&_nc_oc=AdmTOtaGXdOkrWHuscxMJ7aV41U5cm77H-6Ff01cbibYUL-08R38mBxmTMXsuougq3g&_nc_ad=z-m&_nc_cid=0&_nc_zt=23&_nc_ht=instagram.ftgd2-1.fna&_nc_gid=tVnYUWbwH-DBK1rbBmxbVg&oh=00_Afveo9JUaep85CMQI_LQGt-JY9NnZAyWaQeWDi11UU3GFg&oe=69971562","width":240},{"height":150,"url":"https:\/\/instagram.ftgd2-1.fna.fbcdn.net\/v\/t51.82787-15\/619262946_18418533025188966_120910576603499905_n.jpg?stp=c0.192.1152.1152a_dst-jpg_e35_s150x150_tt6&_nc_cat=108&ig_cache_key=MzgxNTg1OTQ0MDE0MjgxMTM4NQ\u00253D\u00253D.3-ccb7-5&ccb=7-5&_nc_sid=58cdad&efg=eyJ2ZW5jb2RlX3RhZyI6InhwaWRzLjExNTJ4MTUzNi5zZHIuQzMifQ\u00253D\u00253D&_nc_ohc=GP4EztoCzW0Q7kNvwHENYuh&_nc_oc=AdmTOtaGXdOkrWHuscxMJ7aV41U5cm77H-6Ff01cbibYUL-08R38mBxmTMXsuougq3g&_nc_ad=z-m&_nc_cid=0&_nc_zt=23&_nc_ht=instagram.ftgd2-1.fna&_nc_gid=tVnYUWbwH-DBK1rbBmxbVg&oh=00_AfvUiyS_S52ke3LAn_YIDKHNvEvQx_S18cpoOx4GTYsglQ&oe=69971562","width":150}]},"code":"DT0s4DGCOud","media_cropping_info":null,"profile_grid_thumbnail_fitting_style":"UNSET","media_overlay_info":null,"preview":null,"product_type":"carousel_container","thumbnails":null,"timeline_pinned_user_ids":[],"upcoming_event":null,"user":{"pk":"5727076965","username":"fitbox_ulcinj","id":"5727076965"},"media_notes":{"items":[]},"like_count":208,"like_and_view_counts_disabled":false,"boosted_status":null,"boost_unavailable_identifier":null,"boost_unavailable_reason":null,"comment_count":0,"comments_disabled":null,"view_count":null,"id":"3815872149949311901_5727076965"},{"pk":"3802630691008023590","accessibility_caption":null,"caption":{"pk":"18031687187770649","text":"Krajem 2025. godine odr\u017eana je godi\u0161nja sjednica Bodybuilding,Fitness i Crossfit Saveza Crne Gore na kojoj su ujedno i dodjeljene nagrade za najboljeg sportistu i najuspje\u0161niji klub protekle godine,kao i zahvalnice i priznanja za postignute rezultate.\nNagradu i pehar za najboljeg sportistu 2025. godine dobio je \u010dlan na\u0161eg FIT BOX kluba Nikola Radinovi\u0107,koji je ove godine postigao fenomenalne rezultate u seniorskoj kategoriji (Svjetsko Prvenstvo \ud83e\udd48,Evropsko \ud83e\udd49,Balkansko \ud83e\udd47 i Dr\u017eavno Prvenstvo \ud83e\udd47).\nDrugoplasirani na rang listi najuspje\u0161nijih sportista bio je na\u0161 Avni Sadriju,koji je tako\u0111e u 2025. godini ostvario zapa\u017eene rezultate u master kategoriji (Svjetsko\ud83e\udd48,Evropsko \ud83e\udd49,Balkansko \ud83e\udd49 i Dr\u017eavno Prvenstvo \ud83e\udd47).\nPriznanje za izuzetne rezultate postignute u prethodnoj godini pripalo je FIT BOX klubu, kao nagrada za ulo\u017eeni trud i rad,i motivacija za postizanje jo\u0161 boljih rezultata u godini koja je pred nama.\nZahvaljujemo se svim takimi\u010darima koji su svojim u\u010de\u0161\u0107em i rezultatom doprinijeli ovom uspjehu,na \u010delu sa trenerom Jasmin Hot,a ujedno i sponzorima koji su pomogli u\u010de\u0161\u0107e na Svjetskom Prvenstvu. \ud83d\ude4c\ud83d\udc4f\ud83c\udfc6\n\u0040ifbb_montenegro \u0040radinovic_nikola"},"audience":null,"carousel_media_count":7,"display_uri":null,"media_type":8,"carousel_media":[{"image_versions2":{"candidates":[{"height":1920,"url":"https:\/\/instagram.ftgd2-1.fna.fbcdn.net\/v\/t51.82787-15\/589570529_18416499157188966_1856129485914964810_n.jpg?stp=dst-jpegr_e35_tt6&_nc_cat=111&ig_cache_key=MzgwMjYzMDY3NDgxODAyNjkxNw\u00253D\u00253D.3-ccb7-5&ccb=7-5&_nc_sid=58cdad&efg=eyJ2ZW5jb2RlX3RhZyI6InhwaWRzLjE0NDB4MTkyMC5oZHIuQzMifQ\u00253D\u00253D&_nc_ohc=EOlE2uJPPEEQ7kNvwGXp89g&_nc_oc=AdnSjNqQmjlUbURoJM7tnleZsDXOoaGX_u4heIA-WVOFFzfTa8MHWnlZ2xRLS0eWBu4&_nc_ad=z-m&_nc_cid=0&_nc_zt=23&_nc_ht=instagram.ftgd2-1.fna&_nc_gid=tVnYUWbwH-DBK1rbBmxbVg&oh=00_AftLMW8OuOhO7zTKGticl0FPv36264W-Te13SEozmSnBdw&oe=6997437D","width":1440},{"height":1440,"url":"https:\/\/instagram.ftgd2-1.fna.fbcdn.net\/v\/t51.82787-15\/589570529_18416499157188966_1856129485914964810_n.jpg?stp=dst-jpegr_e35_p1080x1080_tt6&_nc_cat=111&ig_cache_key=MzgwMjYzMDY3NDgxODAyNjkxNw\u00253D\u00253D.3-ccb7-5&ccb=7-5&_nc_sid=58cdad&efg=eyJ2ZW5jb2RlX3RhZyI6InhwaWRzLjE0NDB4MTkyMC5oZHIuQzMifQ\u00253D\u00253D&_nc_ohc=EOlE2uJPPEEQ7kNvwGXp89g&_nc_oc=AdnSjNqQmjlUbURoJM7tnleZsDXOoaGX_u4heIA-WVOFFzfTa8MHWnlZ2xRLS0eWBu4&_nc_ad=z-m&_nc_cid=0&_nc_zt=23&_nc_ht=instagram.ftgd2-1.fna&_nc_gid=tVnYUWbwH-DBK1rbBmxbVg&oh=00_AfuyZcW3cUp1JLOKbxG2wa0bgyemrU9qqVhKkoG-rGesxA&oe=6997437D","width":1080},{"height":960,"url":"https:\/\/instagram.ftgd2-1.fna.fbcdn.net\/v\/t51.82787-15\/589570529_18416499157188966_1856129485914964810_n.jpg?stp=dst-jpegr_e35_p720x720_tt6&_nc_cat=111&ig_cache_key=MzgwMjYzMDY3NDgxODAyNjkxNw\u00253D\u00253D.3-ccb7-5&ccb=7-5&_nc_sid=58cdad&efg=eyJ2ZW5jb2RlX3RhZyI6InhwaWRzLjE0NDB4MTkyMC5oZHIuQzMifQ\u00253D\u00253D&_nc_ohc=EOlE2uJPPEEQ7kNvwGXp89g&_nc_oc=AdnSjNqQmjlUbURoJM7tnleZsDXOoaGX_u4heIA-WVOFFzfTa8MHWnlZ2xRLS0eWBu4&_nc_ad=z-m&_nc_cid=0&_nc_zt=23&_nc_ht=instagram.ftgd2-1.fna&_nc_gid=tVnYUWbwH-DBK1rbBmxbVg&oh=00_AftGtfOkoXJlPm2OtwQ-tGZ94tRdVxAG1JwDvkXud_OfkA&oe=6997437D","width":720},{"height":853,"url":"https:\/\/ins